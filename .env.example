# --- Database (defaults to SQLite dev.db when unset) ---
# DATABASE_URL=postgresql+psycopg2://options:options@localhost:5432/options_alerts

# --- Market data (need TRADIER_API_KEY or POLYGON_API_KEY; Tradier preferred when both set) ---
TRADIER_API_KEY=
# Sandbox by default; switch for production data:
# TRADIER_BASE_URL=https://api.tradier.com/v1
POLYGON_API_KEY=
FINNHUB_API_KEY=
# Alpha Vantage (premium recommended) — preferred source for stock quotes, daily
# history, fundamentals, and scored news sentiment when set
ALPHA_VANTAGE_API_KEY=
# Optional extra news source (merged with Finnhub headlines)
BENZINGA_API_KEY=

# --- Optional LLM reasoning layer ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Alert channels (configure any subset) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
# SendGrid email (alternative to SMTP; ALERT_EMAIL is the to-address, and the
# from-address unless ALERT_EMAIL_FROM is set — must be a verified SendGrid sender)
SENDGRID_API_KEY=
ALERT_EMAIL=
# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
ALERT_PHONE=
# ntfy.sh push notifications (any unique topic string; subscribe in the ntfy app)
NTFY_TOPIC=

# --- Scanner behaviour ---
# Synthetic data provider — full pipeline with zero API keys (BULL/BEAR test tickers)
USE_MOCK_DATA=false
# Don't re-send the same symbol+direction alert within this window
ALERT_COOLDOWN_MINUTES=60
SCAN_INTERVAL_MINUTES=5
MARKET_HOURS_ONLY=true
CALL_SCORE_THRESHOLD=70
PUT_SCORE_THRESHOLD=-70
DEFAULT_WATCHLIST=AAPL,TSLA,NVDA,AMD,SPY,QQQ,META
